# ── Flood Response Platform — Frontend ────────────────────────────────────────
# Copy this file to .env.local and fill in values before running the app.
# Never commit .env.local to version control.

# Base URL of the FastAPI backend (leave blank to use MSW mocks in dev)
VITE_API_BASE_URL=

# Google Maps / Geocoding API key (used for address-to-coordinates lookup)
# Docs: https://developers.google.com/maps/documentation/geocoding
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox token (optional — swap TileLayer URL in Map.tsx to use Mapbox tiles)
# VITE_MAPBOX_TOKEN=

# NOAA weather API key (optional — used by backend polling job, not the frontend)
# Documented here for completeness so a second agent can wire it up.
# VITE_NOAA_API_KEY=

# Twilio Account SID and Auth Token are backend-only secrets.
# Do NOT expose them here. See BACKEND_SPEC.md for the backend .env template.
